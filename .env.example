# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email transacional
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=Mariana Explica
EMAIL_FROM_EMAIL=your_sender_email
EMAIL_REPLY_TO=your_reply_to_email
EMAIL_SMTP_HOST=your_smtp_host
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=your_smtp_user
EMAIL_SMTP_PASSWORD=your_smtp_password
EMAIL_SMTP_SECURE=true

# API
VITE_API_BASE_URL=your_api_base_url

# Edge Functions — nunca usar prefixo VITE_ nestes segredos
STRIPE_SECRET_KEY_TEST=your_stripe_test_secret
STRIPE_SECRET_KEY_LIVE=your_stripe_live_secret
STRIPE_WEBHOOK_SECRET_TEST=your_stripe_test_webhook_secret
STRIPE_WEBHOOK_SECRET_LIVE=your_stripe_live_webhook_secret
CRON_SECRET=your_internal_cron_secret

# Moloni OAuth + cifra aplicacional dos tokens mutáveis
MOLONI_CLIENT_ID=your_moloni_client_id
MOLONI_CLIENT_SECRET=your_moloni_client_secret
MOLONI_REDIRECT_URI=https://your-project.supabase.co/functions/v1/moloni-oauth-callback
MOLONI_TOKEN_ENCRYPTION_KEY=generate_a_long_random_secret
