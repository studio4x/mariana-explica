{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/public/site-asset",
      "destination": "https://gookhgufsxeplelpdaua.supabase.co/functions/v1/public-site-asset"
    },
    {
      "source": "/api/public/course-media",
      "destination": "https://gookhgufsxeplelpdaua.supabase.co/functions/v1/public-course-media"
    },
    {
      "source": "/api/public/profile-avatar",
      "destination": "https://gookhgufsxeplelpdaua.supabase.co/functions/v1/public-profile-avatar"
    },
    {
      "source": "/((?!assets/|favicon.ico|manifest.webmanifest|sw.js|offline.html|icons/).*)",
      "destination": "/"
    }
  ]
}
